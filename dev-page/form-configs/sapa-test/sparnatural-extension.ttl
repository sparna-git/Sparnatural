 ?domain $property ?uri .
 ?uri rdfs:label ?label .
 FILTER(STRSTARTS(LCASE(STR(?label)), LCASE(\"$key\"))) 
} 
ORDER BY UCASE(STR(?label))
LIMIT 15""" .

