  datasources:queryTemplate datasources:query_list_label_with_range_alpha;
  datasources:labelProperty rico:name .

spao-sparnatural:search_rdfslabel_without_language a datasources:SparqlDatasource;
  datasources:queryString """PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rico: <https://www.ica.org/standards/RiC/ontology#>
SELECT DISTINCT ?uri ?label
WHERE {
 ?domain $type $domain .
 ?domain $property ?uri .
 ?uri $type $range .
 ?uri rico:name ?label .
 FILTER(isIRI(?uri))
 FILTER(CONTAINS(LCASE(STR(?label)), LCASE(\"$key\"))) 
} 
ORDER BY UCASE(?label)
LIMIT 15""" .

spao-i:tree_root_archivalplace_datasource a datasources:SPARQLQuery;
  datasources:queryString """PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX spao: <http://ontology.performing-arts.ch/>
PREFIX rico: <https://www.ica.org/standards/RiC/ontology#>
SELECT ?uri ?label WHERE {
 ?uri a spao:ArchivalPlace .
 ?uri rdfs:label ?label .
 FILTER(lang(?label) = \"\" || lang(?label) = $lang)
 FILTER NOT EXISTS{?uri rico:containedBy ?parent}
}""" .

spao-i:tree_children_archivalplace_datasource a datasources:SPARQLQuery;
  datasources:queryString """PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX spao: <http://ontology.performing-arts.ch/>
PREFIX rico: <https://www.ica.org/standards/RiC/ontology#>
SELECT DISTINCT ?uri ?label ?hasChildren (COUNT(?x) AS ?count) WHERE {
 $node ^rico:containedBy ?uri .
 ?uri rdfs:label ?label .
 FILTER(lang(?label) = \"\" || lang(?label) = $lang)
 OPTIONAL { ?uri ^rico:containedBy ?children }
 BIND(IF(bound(?children),true,false) AS ?hasChildren)

 OPTIONAL {
 ?x a $domain .
 ?x $property ?uri .
 }
}
GROUP BY ?uri ?label ?hasChildren
ORDER BY ?label""" .

spao-i:tree_root_carriertype_datasource a datasources:SPARQLQuery;
  datasources:queryString """PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX spao: <http://ontology.performing-arts.ch/>
PREFIX rico: <https://www.ica.org/standards/RiC/ontology#>
SELECT ?uri ?label WHERE {
 ?uri a skos:Concept .
 ?uri skos:topConceptOf <http://vocab.performing-arts.ch/fv> .
 ?uri skos:prefLabel ?label .
 FILTER(lang(?label) = \"\" || lang(?label) = $lang)
}""" .

spao-i:tree_children_skos_datasource a datasources:SPARQLQuery;
  datasources:queryString """PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX spao: <http://ontology.performing-arts.ch/>
PREFIX rico: <https://www.ica.org/standards/RiC/ontology#>
SELECT DISTINCT ?uri ?label ?hasChildren (COUNT(?x) AS ?count) WHERE {
 $node ^skos:broader ?uri .
 ?uri skos:prefLabel ?label .
 FILTER(lang(?label) = \"\" || lang(?label) = $lang)
 OPTIONAL { ?uri ^skos:broader ?children }
 BIND(IF(bound(?children),true,false) AS ?hasChildren)

 OPTIONAL {
 ?x a $domain .
 ?x $property ?uri .
 }
}
GROUP BY ?uri ?label ?hasChildren
ORDER BY ?label""" .

