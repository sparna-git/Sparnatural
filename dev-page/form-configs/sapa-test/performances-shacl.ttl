spao-pf:Performance_Serie_P9_consists_of sh:path crm:P9_consists_of;
  sh:name "consists of (participation)"@en;
  skos:editorialNote """Toutes les singles sont liées à une série:

PREFIX crm: <http://www.cidoc-crm.org/cidoc-crm/>
PREFIX frbroo: <http://iflastandards.info/ns/fr/frbr/frbroo/>
PREFIX schema: <http://schema.org/>
SELECT ?this
WHERE {
 ?this a frbroo:F31_Performance .
 ?this schema:additionalType <http://vocab.performing-arts.ch/hlsin> .
 FILTER NOT EXISTS { 
 ?serie a frbroo:F31_Performance .
 ?serie schema:additionalType <http://vocab.performing-arts.ch/hlser> .
 ?serie crm:P9_consists_of ?this .
 }
}"""@en;
  sh:nodeKind sh:IRI;
  sh:class crm:E7_Activity;
  sh:node spao-pf:Activity_Participation .

spao-pf:Performance_Serie_R25_performed sh:path frbroo:R25_performed;
  sh:name "performed"@en;
  skos:editorialNote """Toutes les séries sont liées à un plan:

PREFIX crm: <http://www.cidoc-crm.org/cidoc-crm/>
PREFIX frbroo: <http://iflastandards.info/ns/fr/frbr/frbroo/>
PREFIX schema: <http://schema.org/>
SELECT ?this
WHERE {
 ?this a frbroo:F31_Performance .
 ?this schema:additionalType <http://vocab.performing-arts.ch/hlser> .
 FILTER NOT EXISTS { 
 ?this frbroo:R25_performed ?plan
 }
}"""@en;
  sh:minCount 1;
  sh:maxCount 1;
  sh:nodeKind sh:IRI;
  sh:class frbroo:F25_Performance_Plan .

