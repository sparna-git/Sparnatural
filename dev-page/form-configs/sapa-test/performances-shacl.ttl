spao-pf:Performance_Serie_label sh:path rdfs:label;
  sh:name "label"@en;
  skos:editorialNote """Bizarre qu'on n'ait pas une cardinalité minimale.

Requête SPARQL:

PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX frbroo: <http://iflastandards.info/ns/fr/frbr/frbroo/>
PREFIX spav: <http://vocab.performing-arts.ch/>
SELECT ?x
WHERE {
 ?x a frbroo:F31_Performance
 FILTER NOT EXISTS { ?x rdfs:label ?l }
}
LIMIT 1000

On met une cardinalité minimale à 1"""@en;
  sh:minCount 1;
  sh:maxCount 1;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:string .

