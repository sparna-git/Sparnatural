spao-pf:F25_Performance_Plan_comment sh:path rdfs:comment;
  sh:name "comment"@en;
  skos:editorialNote """Environ 150 Plan ne sont pas référencés dans des works:

Exemple http://data.performing-arts.ch/w/6928a7dc-496c-42e4-a171-d4734164b9a9

Vient du formulaire

PREFIX crm: <http://www.cidoc-crm.org/cidoc-crm/>
PREFIX frbroo: <http://iflastandards.info/ns/fr/frbr/frbroo/>
PREFIX schema: <http://schema.org/>
SELECT ?this
WHERE {
 ?this a frbroo:F25_Performance_Plan .
 FILTER NOT EXISTS { 
 ?performanceWork frbroo:R12_is_realised_in ?this .
 }
}

On laisse comme ça"""@en;
  sh:maxCount 1;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:string .

