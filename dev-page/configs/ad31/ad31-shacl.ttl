  sh:nodeKind sh:IRI;
  sh:pattern "^https://data.archives.haute-garonne.fr/evenement/[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}#date-[debut|fin]";
  foaf:depiction sacs:Diagram_Activity_Procedure;
  sh:closed true;
  sh:ignoredProperties _:6a507bd3afaa4d4099437ca6131f3514569;
  shacl-play:background-color "ded9c3";
  sh:property sacs:Date_normalizedDateValue, sacs:Date_expressedDate .

_:6a507bd3afaa4d4099437ca6131f3514569 rdf:first rdf:type;
  rdf:rest rdf:nil .

