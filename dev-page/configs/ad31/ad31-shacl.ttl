sacs:BusinessRule_1 a sh:SPARQLConstraint;
  dct:description "Les URI d'Identifiants doivent commencer par l'URI de leur objet"@fr;
  sh:message "L'URI d'un identifiant ne commence pas par l'URI de son objet";
  sh:select """PREFIX rico: <https://www.ica.org/standards/RiC/ontology#>
SELECT $this
WHERE {
 $this ^rico:hasOrHadIdentifier ?object .
 FILTER(!STRSTARTS(STR($this), STR(?object)))
}""" .
