    sacs:Notice_hasOrHadInstantiation, sacs:Notice_documents, sacs:Notice_hasOrHadIdentifier,
    sacs:Notice_wasCreatedByAgentWithRole, sacs:Notice_hasOrganicOrFunctionalProvenance .

