shape:SpecialitePharmaceutique_label sh:path rdfs:label;
  sh:name "a pour désignation"@fr;
  sh:description "Nom de spécialité"@fr;
  sh:nodeKind sh:Literal;
  sh:node shape:Text;
  dash:searchWidget config-core:SearchProperty;
