  sh:nodeKind sh:Literal;
  sh:node shape:Text;
  dash:searchWidget config-core:SearchProperty .

shape:Presentation_CIP13 sh:path med:CIP13;
  sh:name "code CIP13"@fr;
  sh:description "Code CIP13 (code principal de la présentation)"@fr;
  sh:nodeKind sh:Literal;
  sh:node shape:Code;
